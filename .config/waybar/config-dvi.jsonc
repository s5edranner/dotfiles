{
  "layer": "top",
  "height": 35,
  "output": "DVI-D-1",
  "width": 1440,
  
  "modules-left": [
    "clock#date",
    "clock",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window"
  ],

  "clock": {
    "tooltip": false
  },
  "clock#date": {
    "format": "{:%d/%m}",
    "interval": 60,
    "tooltip": false
  },
  "hyprland/window": {
    "format": "{}",
    "tooltip": false
  }
}
